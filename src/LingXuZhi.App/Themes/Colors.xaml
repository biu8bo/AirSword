<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="PanelBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="PreviewBackgroundBrush" Color="#0B1120" />
    <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F5F9" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="MutedBrush" Color="#272F42" />

    <FontFamily x:Key="MonoFont">Cascadia Mono,Consolas</FontFamily>

</ResourceDictionary>
