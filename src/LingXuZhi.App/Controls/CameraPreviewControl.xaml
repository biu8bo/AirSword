<UserControl
    x:Class="LingXuZhi.App.Controls.CameraPreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PreviewBackgroundBrush}" CornerRadius="8">
        <Image Source="{x:Bind ViewModel.PreviewBitmap, Mode=OneWay}" Stretch="Uniform" />

        <!-- 左下角:分辨率 / FPS 叠加 -->
        <Border
            Margin="12"
            Padding="10,6"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Background="#B31E293B"
            CornerRadius="6">
            <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock
                    FontFamily="{StaticResource MonoFont}"
                    FontSize="13"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{x:Bind ViewModel.FrameResolution, Mode=OneWay}" />
                <TextBlock
                    FontFamily="{StaticResource MonoFont}"
                    FontSize="13"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{x:Bind ViewModel.FpsText, Mode=OneWay}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
