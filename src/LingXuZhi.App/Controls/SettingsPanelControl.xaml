<UserControl
    x:Class="LingXuZhi.App.Controls.SettingsPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Padding="16"
        Background="{StaticResource PanelBrush}"
        BorderBrush="{StaticResource PanelBorderBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <StackPanel Spacing="12">
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="设置" />

            <ComboBox
                MinHeight="44"
                HorizontalAlignment="Stretch"
                DisplayMemberPath="Name"
                Header="摄像头设备"
                ItemsSource="{x:Bind ViewModel.CameraDevices}"
                PlaceholderText="正在检测…"
                SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}" />

            <ComboBox
                MinHeight="44"
                HorizontalAlignment="Stretch"
                Header="分辨率"
                ItemsSource="{x:Bind ViewModel.Resolutions}"
                SelectedItem="{x:Bind ViewModel.SelectedResolution, Mode=TwoWay}" />

            <ToggleSwitch
                Header="镜像翻转"
                IsOn="{x:Bind ViewModel.Settings.Mirror, Mode=TwoWay}" />

            <StackPanel Spacing="4">
                <Grid>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="鼠标灵敏度" />
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource MonoFont}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind Format2(ViewModel.Settings.Sensitivity), Mode=OneWay}" />
                </Grid>
                <Slider
                    MinHeight="44"
                    Maximum="3"
                    Minimum="0.2"
                    StepFrequency="0.1"
                    Value="{x:Bind ViewModel.Settings.Sensitivity, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <Grid>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="平滑系数" />
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource MonoFont}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind Format2(ViewModel.Settings.Smoothing), Mode=OneWay}" />
                </Grid>
                <Slider
                    MinHeight="44"
                    Maximum="1"
                    Minimum="0"
                    StepFrequency="0.05"
                    Value="{x:Bind ViewModel.Settings.Smoothing, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <Grid>
                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="死区半径" />
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontFamily="{StaticResource MonoFont}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind FormatPx(ViewModel.Settings.DeadZoneRadius), Mode=OneWay}" />
                </Grid>
                <Slider
                    MinHeight="44"
                    Maximum="200"
                    Minimum="0"
                    StepFrequency="5"
                    Value="{x:Bind ViewModel.Settings.DeadZoneRadius, Mode=TwoWay}" />
            </StackPanel>

            <ToggleSwitch
                Header="启用鼠标仿真(阶段 3 生效)"
                IsOn="{x:Bind ViewModel.Settings.MouseSimulationEnabled, Mode=TwoWay}" />
        </StackPanel>
    </Border>
</UserControl>
