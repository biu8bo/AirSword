<UserControl
    x:Class="LingXuZhi.App.Controls.DebugPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Padding="16"
        Background="{StaticResource PanelBrush}"
        BorderBrush="{StaticResource PanelBorderBrush}"
        BorderThickness="1"
        CornerRadius="8">
        <StackPanel Spacing="8">
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="调试数据" />

            <Grid ColumnSpacing="8" RowSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="手势状态" />
                <TextBlock
                    Grid.Row="0" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.GestureState, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="1" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="状态转移" />
                <TextBlock
                    Grid.Row="1" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.StateTransition, Mode=OneWay}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Grid.Row="2" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="识别状态" />
                <TextBlock
                    Grid.Row="2" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.DetectionState, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="3" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="采集 FPS" />
                <TextBlock
                    Grid.Row="3" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.FpsText, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="4" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="处理 FPS" />
                <TextBlock
                    Grid.Row="4" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.ProcessFpsText, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="5" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="帧分辨率" />
                <TextBlock
                    Grid.Row="5" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.FrameResolution, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="6" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="处理耗时" />
                <TextBlock
                    Grid.Row="6" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.ProcessingTime, Mode=OneWay}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Grid.Row="7" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="手掌置信度" />
                <TextBlock
                    Grid.Row="7" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.PalmScore, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="8" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="边界框" />
                <TextBlock
                    Grid.Row="8" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.BoundingBoxText, Mode=OneWay}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Grid.Row="9" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="旋转角" />
                <TextBlock
                    Grid.Row="9" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.RotationText, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="10" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="原始指针" />
                <TextBlock
                    Grid.Row="10" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.RawPointerText, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="11" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="平滑指针" />
                <TextBlock
                    Grid.Row="11" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.SmoothedPointerText, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="12" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="死区" />
                <TextBlock
                    Grid.Row="12" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.DeadZoneText, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="13" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="鼠标位移" />
                <TextBlock
                    Grid.Row="13" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.MouseDeltaText, Mode=OneWay}" />

                <TextBlock
                    Grid.Row="14" Grid.Column="0"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="点击/滚轮" />
                <TextBlock
                    Grid.Row="14" Grid.Column="1"
                    FontFamily="{StaticResource MonoFont}"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ClickScrollText(ViewModel.ClickCountText, ViewModel.ScrollCountText), Mode=OneWay}" />
            </Grid>

            <TextBlock
                Margin="0,8,0,0"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="关键点坐标" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.LandmarkLines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="12"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
