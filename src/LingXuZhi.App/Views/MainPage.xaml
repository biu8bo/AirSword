<Page
    x:Class="LingXuZhi.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LingXuZhi.App.Controls"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏(SetTitleBar 拖拽区,替代系统标题栏) -->
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="16,0,0,0"
            Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <!-- 预留系统窗口按钮区域(最小化/最大化/关闭,约 3 × 46 逻辑像素) -->
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <Image
                x:Name="TitleLogo"
                Grid.Column="0"
                Width="22"
                Height="22"
                VerticalAlignment="Center" />

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="凌虚指 AirSword" />

            <Border
                Grid.Column="2"
                Padding="10,4"
                VerticalAlignment="Center"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse
                        Width="8"
                        Height="8"
                        VerticalAlignment="Center"
                        Fill="{StaticResource SuccessBrush}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{x:Bind ViewModel.GestureState, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <TextBlock
                Grid.Column="4"
                VerticalAlignment="Center"
                FontFamily="{StaticResource MonoFont}"
                FontSize="13"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{x:Bind ViewModel.FpsText, Mode=OneWay}" />
        </Grid>

        <Grid
            Grid.Row="1"
            Padding="16,12,16,16"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="170" />
            </Grid.RowDefinitions>

            <!-- 主体:左侧预览 + 右侧面板 -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" MinWidth="320" />
                </Grid.ColumnDefinitions>

                <controls:CameraPreviewControl Grid.Column="0" />

                <ScrollViewer x:Name="RightPanelScroll" Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <controls:SettingsPanelControl />
                        <controls:DebugPanelControl />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- 底部运行日志 -->
            <Border
                Grid.Row="1"
                Background="{StaticResource MutedBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="16,10,16,0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="运行日志" />

                <ListView
                    Grid.Row="1"
                    Margin="8,0,8,8"
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind ViewModel.LogLines}"
                    SelectionMode="None">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel VerticalAlignment="Bottom" ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight" Value="22" />
                            <Setter Property="Padding" Value="8,1" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{x:Bind}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
