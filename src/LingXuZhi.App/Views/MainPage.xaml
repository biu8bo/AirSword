<Page
    x:Class="LingXuZhi.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:LingXuZhi.App.Controls"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 自定义标题栏(SetTitleBar 拖拽区,替代系统标题栏) -->
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Padding="16,0,0,0"
            Background="{StaticResource AppBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="0,0,0,1"
            ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <!-- 预留系统窗口按钮区域(最小化/最大化/关闭,约 3 × 46 逻辑像素) -->
                <ColumnDefinition Width="150" />
            </Grid.ColumnDefinitions>

            <!-- 拖拽区只覆盖左侧非交互区域,右侧帮助按钮保持可点击 -->
            <Border
                x:Name="DragRegion"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Margin="-16,0,0,0"
                Background="Transparent" />

            <Image
                x:Name="TitleLogo"
                Grid.Column="0"
                Width="22"
                Height="22"
                VerticalAlignment="Center" />

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="15"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="凌虚指 AirSword" />

            <Border
                Grid.Column="2"
                Padding="10,4"
                VerticalAlignment="Center"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Ellipse
                        Width="8"
                        Height="8"
                        VerticalAlignment="Center"
                        Fill="{StaticResource SuccessBrush}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{x:Bind ViewModel.GestureState, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <TextBlock
                Grid.Column="4"
                VerticalAlignment="Center"
                FontFamily="{StaticResource MonoFont}"
                FontSize="13"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{x:Bind ViewModel.FpsText, Mode=OneWay}" />

            <Button
                x:Name="HelpButton"
                Grid.Column="5"
                Width="44"
                Height="40"
                Margin="4,0,4,0"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Click="OnHelpClick"
                ToolTipService.ToolTip="操作说明 (F1)">
                <Button.KeyboardAccelerators>
                    <KeyboardAccelerator Key="F1" />
                </Button.KeyboardAccelerators>
                <FontIcon
                    FontSize="16"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Glyph="&#xE897;" />
            </Button>
        </Grid>

        <Grid
            Grid.Row="1"
            Padding="16,12,16,16"
            RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="170" />
            </Grid.RowDefinitions>

            <!-- 主体:左侧预览 + 右侧面板 -->
            <Grid Grid.Row="0" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" MinWidth="320" />
                </Grid.ColumnDefinitions>

                <controls:CameraPreviewControl Grid.Column="0" />

                <ScrollViewer x:Name="RightPanelScroll" Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="12">
                        <controls:SettingsPanelControl />
                        <controls:DebugPanelControl />
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- 底部运行日志 -->
            <Border
                Grid.Row="1"
                Background="{StaticResource MutedBrush}"
                BorderBrush="{StaticResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="16,10,16,0"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="运行日志" />

                <ListView
                    Grid.Row="1"
                    Margin="8,0,8,8"
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind ViewModel.LogLines}"
                    SelectionMode="None">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel VerticalAlignment="Bottom" ItemsUpdatingScrollMode="KeepLastItemInView" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight" Value="22" />
                            <Setter Property="Padding" Value="8,1" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="12"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{x:Bind}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
            </Border>
        </Grid>

        <!-- 操作说明帮助对话框(标题栏 ? 按钮 / F1 打开) -->
        <ContentDialog
            x:Name="HelpDialog"
            Title="操作说明"
            Background="{StaticResource PanelBrush}"
            CloseButtonText="知道了"
            DefaultButton="Close"
            Foreground="{StaticResource TextPrimaryBrush}">
            <ScrollViewer MaxHeight="520" VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="480" Spacing="14">
                    <TextBlock
                        FontSize="13"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="面对摄像头,让手完整入画。所有手势需保持数帧才生效(去抖),阈值与灵敏度可在右侧设置面板调整。"
                        TextWrapping="Wrap" />

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentBrush}"
                            Text="食指 · 移动指针" />
                        <TextBlock
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="食指伸直、中指收起,其他手指不参与判定。指针跟随食指尖平滑移动;手停在画面中央虚线圆(死区)内时指针静止。注意:中指也伸直时不识别为移动,四指全伸直会进入滚轮手势。"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentBrush}"
                            Text="拇指–食指捏合 · 左键" />
                        <TextBlock
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            TextWrapping="Wrap">
                            <Run Text="• 单击:原地捏合后松开,立即触发左键" />
                            <LineBreak />
                            <Run Text="• 双击:快速连续两次单击即可(与普通鼠标相同,无需专用手势)" />
                            <LineBreak />
                            <Run Text="• 拖拽:捏住并移动,松开即释放" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentBrush}"
                            Text="比耶并拢 · 右键" />
                        <TextBlock
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="食指与中指伸直做比耶,再把两指尖并拢一下,触发一次右键;并拢不放不会连点。无名指、小指宜收起,避免被识别成滚轮。"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentBrush}"
                            Text="张开手掌 · 滚轮" />
                        <TextBlock
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            TextWrapping="Wrap">
                            <Run Text="• 五指张开(拇指也张开):持续向上滚动" />
                            <LineBreak />
                            <Run Text="• 四指张开、拇指弯向掌心:持续向下滚动" />
                            <LineBreak />
                            <Run Text="• 切换拇指开合即可换向,收回手势停止滚动" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentBrush}"
                            Text="小贴士" />
                        <TextBlock
                            FontSize="13"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            TextWrapping="Wrap">
                            <Run Text="• 手出画或被遮挡时识别中断,拖拽会自动释放按键" />
                            <LineBreak />
                            <Run Text="• 只想看识别效果时,可关闭设置中的「启用鼠标仿真」" />
                            <LineBreak />
                            <Run Text="• 移动抖动可调大「平滑系数」" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Page>
